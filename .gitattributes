# Set default behavior to automatically normalize line endings
* text=auto

# Force LF for all source files regardless of OS
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.html text eol=lf

# Ensure SVG brand assets are treated as text with LF
*.svg text eol=lf

# Declare binary files to prevent normalization
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
